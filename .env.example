# Your Groq API key for Language Models (Researcher, Coder, QA)
# Get yours here: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# Your GitHub Personal Access Token (for cloning repos, making PRs)
# Get yours here: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN
